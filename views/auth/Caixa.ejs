    <script>
        // Funções para navegação entre páginas
        function showCaixaList() {
            document.getElementById('page-title').textContent = 'Controle de Caixa';
            document.getElementById('page-content').innerHTML = document.querySelector('#page-content').innerHTML;
        }

        function showAbrirCaixa() {
            document.getElementById('page-title').textContent = 'Abrir Caixa';
            const template = document.getElementById('abrir-caixa-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
            
            // Inicializar funcionalidades do formulário
            document.getElementById('abrir-caixa-form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Simular sucesso
                document.getElementById('success-alert').textContent = 'Caixa aberto com sucesso!';
                document.getElementById('success-alert').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('success-alert').style.display = 'none';
                    showCaixaList();
                }, 3000);
            });
        }

        function showDetalhesCaixa() {
            document.getElementById('page-title').textContent = 'Detalhes do Caixa';
            const template = document.getElementById('detalhes-caixa-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
            
            // Inicializar funcionalidades dos formulários
            document.getElementById('fechar-caixa-form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                if (confirm('Tem certeza que deseja fechar este caixa?')) {
                    // Simular sucesso
                    document.getElementById('success-alert').textContent = 'Caixa fechado com sucesso!';
                    document.getElementById('success-alert').style.display = 'block';
                    setTimeout(() => {
                        document.getElementById('success-alert').style.display = 'none';
                        showCaixaList();
                    }, 3000);
                }
            });
            
            document.getElementById('adicionar-movimento-form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Simular sucesso
                document.getElementById('success-alert').textContent = 'Movimento adicionado com sucesso!';
                document.getElementById('success-alert').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('success-alert').style.display = 'none';
                    // Limpar formulário
                    document.getElementById('adicionar-movimento-form').reset();
                }, 3000);
            });
        }

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            // Ativar/desativar itens do menu
            const menuItems = document.querySelectorAll('.nav-menu a');
            menuItems.forEach(item => {
                item.addEventListener('click', function() {
                    menuItems.forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                });
            });
            
            // Simular notificações
            const notification = document.querySelector('.notification');
            notification.addEventListener('click', function() {
                alert('Você tem 2 caixas abertos que precisam de atenção');
            });
            
            // Filtro de status
            document.getElementById('status').addEventListener('change', function() {
                // Simulação de filtro - em uma aplicação real, isso faria uma requisição ao servidor
                const status = this.value;
                const rows = document.querySelectorAll('.data-table tbody tr');
                
                rows.forEach(row => {
                    if (status === 'todos') {
                        row.style.display = '';
                    } else {
                        const statusCell = row.querySelector('.status-badge');
                        if (statusCell) {
                            const rowStatus = statusCell.classList.contains('status-aberto') ? 'aberto' : 'fechado';
                            row.style.display = rowStatus === status ? '' : 'none';
                        }
                    }
                });
            });
        });
    </script>
