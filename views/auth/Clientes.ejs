    <script>
        // Funções para navegação entre páginas
        function showClientesList() {
            document.getElementById('page-title').textContent = 'Gestão de Clientes';
            document.getElementById('page-content').innerHTML = document.querySelector('#page-content').innerHTML;
        }

        function showNovoCliente() {
            document.getElementById('page-title').textContent = 'Novo Cliente';
            const template = document.getElementById('novo-cliente-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
            
            // Inicializar funcionalidades do formulário
            document.getElementById('novo-cliente-form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Simular sucesso
                document.getElementById('success-alert').textContent = 'Cliente cadastrado com sucesso!';
                document.getElementById('success-alert').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('success-alert').style.display = 'none';
                    showClientesList();
                }, 3000);
            });
        }

        function showDetalhesCliente() {
            document.getElementById('page-title').textContent = 'Detalhes do Cliente';
            const template = document.getElementById('detalhes-cliente-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
        }

        function showEditarCliente() {
            // Similar ao novo cliente, mas preenchendo os campos com dados existentes
            showNovoCliente();
            document.getElementById('page-title').textContent = 'Editar Cliente';
            document.querySelector('.btn-block').textContent = 'Atualizar Cliente';
            
            // Preencher campos com dados do cliente (simulação)
            document.getElementById('nome').value = 'João Silva';
            document.getElementById('email').value = 'joao.silva@email.com';
            document.getElementById('telefone').value = '(11) 99999-9999';
        }

        // Funções auxiliares
        function togglePessoaJuridica() {
            const tipo = document.getElementById('tipo_cliente').value;
            const pfFields = document.getElementById('pessoa_fisica_fields');
            const pjFields = document.getElementById('pessoa_juridica_fields');
            
            if (tipo === 'pessoa_fisica') {
                pfFields.style.display = 'block';
                pjFields.style.display = 'none';
            } else {
                pfFields.style.display = 'none';
                pjFields.style.display = 'block';
            }
        }

        function openTab(evt, tabName) {
            const tabcontent = document.getElementsByClassName('tab-content');
            for (let i = 0; i < tabcontent.length; i++) {
                tabcontent[i].classList.remove('active');
            }
            
            const tablinks = document.getElementsByClassName('tab');
            for (let i = 0; i < tablinks.length; i++) {
                tablinks[i].classList.remove('active');
            }
            
            document.getElementById(tabName).classList.add('active');
            evt.currentTarget.classList.add('active');
        }

        function aplicarFiltros() {
            const status = document.getElementById('status').value;
            const tipo = document.getElementById('tipo').value;
            const searchTerm = document.getElementById('search-clients').value.toLowerCase();
            
            const rows = document.querySelectorAll('#clientes-table tbody tr');
            
            rows.forEach(row => {
                const statusCell = row.querySelector('.status-badge');
                const tipoCell = row.cells[4];
                const nomeCell = row.cells[1];
                
                let showRow = true;
                
                // Filtro por status
                if (status !== 'todos') {
                    const rowStatus = statusCell.classList.contains('status-ativo') ? 'ativo' : 
                                   statusCell.classList.contains('status-inativo') ? 'inativo' : 'preferencial';
                    if (status !== rowStatus) showRow = false;
                }
                
                // Filtro por tipo
                if (tipo !== 'todos') {
                    const rowTipo = tipoCell.textContent.includes('Física') ? 'pessoa_fisica' : 'pessoa_juridica';
                    if (tipo !== rowTipo) showRow = false;
                }
                
                // Filtro por busca
                if (searchTerm && !nomeCell.textContent.toLowerCase().includes(searchTerm)) {
                    showRow = false;
                }
                
                row.style.display = showRow ? '' : 'none';
            });
        }

        function limparFiltros() {
            document.getElementById('status').value = 'todos';
            document.getElementById('tipo').value = 'todos';
            document.getElementById('search-clients').value = '';
            aplicarFiltros();
        }

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            // Ativar/desativar itens do menu
            const menuItems = document.querySelectorAll('.nav-menu a');
            menuItems.forEach(item => {
                item.addEventListener('click', function() {
                    menuItems.forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                });
            });
            
            // Busca em tempo real
            document.getElementById('search-clients').addEventListener('input', aplicarFiltros);
            
            // Simular notificações
            const notification = document.querySelector('.notification');
            notification.addEventListener('click', function() {
                alert('Você tem 5 clientes que precisam de acompanhamento');
            });
        });
    </script>
