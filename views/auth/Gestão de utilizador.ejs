    <script>
        // Dados de permissões por perfil
        const permissoesPorPerfil = {
            'administrador': {
                'Dashboard': ['Visualizar Dashboard'],
                'Vendas': ['Visualizar Vendas', 'Criar Vendas', 'Cancelar Vendas', 'Exportar Vendas'],
                'Estoque': ['Visualizar Produtos', 'Gerir Produtos', 'Gerir Categorias', 'Ajustar Estoque'],
                'Caixas': ['Visualizar Caixas', 'Abrir/Fechar Caixas', 'Gerir Movimentos'],
                'Clientes': ['Visualizar Clientes', 'Gerir Clientes', 'Exportar Clientes'],
                'Utilizadores': ['Visualizar Utilizadores', 'Gerir Utilizadores', 'Gerir Perfis'],
                'Relatórios': ['Visualizar Relatórios', 'Exportar Relatórios'],
                'Configurações': ['Acessar Configurações']
            },
            'gerente': {
                'Dashboard': ['Visualizar Dashboard'],
                'Vendas': ['Visualizar Vendas', 'Criar Vendas', 'Cancelar Vendas'],
                'Estoque': ['Visualizar Produtos', 'Gerir Produtos', 'Gerir Categorias'],
                'Caixas': ['Visualizar Caixas', 'Abrir/Fechar Caixas'],
                'Clientes': ['Visualizar Clientes', 'Gerir Clientes'],
                'Relatórios': ['Visualizar Relatórios']
            },
            'vendedor': {
                'Dashboard': ['Visualizar Dashboard'],
                'Vendas': ['Visualizar Vendas', 'Criar Vendas'],
                'Estoque': ['Visualizar Produtos'],
                'Clientes': ['Visualizar Clientes', 'Gerir Clientes']
            },
            'caixa': {
                'Vendas': ['Visualizar Vendas', 'Criar Vendas'],
                'Caixas': ['Visualizar Caixas']
            },
            'estoque': {
                'Dashboard': ['Visualizar Dashboard'],
                'Estoque': ['Visualizar Produtos', 'Gerir Produtos', 'Ajustar Estoque'],
                'Relatórios': ['Visualizar Relatórios']
            }
        };

        // Funções para navegação entre páginas
        function showUtilizadoresList() {
            document.getElementById('page-title').textContent = 'Gestão de Utilizadores';
            document.getElementById('page-content').innerHTML = document.querySelector('#page-content').innerHTML;
        }

        function showNovoUtilizador() {
            document.getElementById('page-title').textContent = 'Novo Utilizador';
            const template = document.getElementById('novo-utilizador-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
            
            // Inicializar funcionalidades do formulário
            document.getElementById('novo-utilizador-form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Validar senhas
                const senha = document.getElementById('senha').value;
                const confirmarSenha = document.getElementById('confirmar_senha').value;
                
                if (senha !== confirmarSenha) {
                    alert('As senhas não coincidem!');
                    return;
                }
                
                // Simular sucesso
                document.getElementById('success-alert').textContent = 'Utilizador cadastrado com sucesso!';
                document.getElementById('success-alert').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('success-alert').style.display = 'none';
                    showUtilizadoresList();
                }, 3000);
            });
            
            // Atualizar permissões quando o perfil mudar
            document.getElementById('perfil').addEventListener('change', function() {
                atualizarPermissoes(this.value);
            });
        }

        function showDetalhesUtilizador() {
            document.getElementById('page-title').textContent = 'Detalhes do Utilizador';
            const template = document.getElementById('detalhes-utilizador-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
        }

        function showEditarUtilizador() {
            // Similar ao novo utilizador, mas preenchendo os campos com dados existentes
            showNovoUtilizador();
            document.getElementById('page-title').textContent = 'Editar Utilizador';
            document.querySelector('.btn-block').textContent = 'Atualizar Utilizador';
            
            // Preencher campos com dados do utilizador (simulação)
            document.getElementById('nome').value = 'João Silva';
            document.getElementById('email').value = 'joao.silva@bommuno.com';
            document.getElementById('telefone').value = '(11) 99999-9999';
            document.getElementById('departamento').value = 'ti';
            document.getElementById('perfil').value = 'administrador';
            document.getElementById('status').value = 'ativo';
            
            // Remover campos de senha para edição
            document.getElementById('senha').closest('.form-group').style.display = 'none';
            document.getElementById('confirmar_senha').closest('.form-group').style.display = 'none';
            
            // Atualizar permissões
            atualizarPermissoes('administrador');
        }

        // Funções auxiliares
        function atualizarPermissoes(perfil) {
            const permissoesInfo = document.getElementById('permissoes-info');
            const permissoes = permissoesPorPerfil[perfil] || {};
            
            let html = `<h4>Permissões do Perfil: ${perfil.charAt(0).toUpperCase() + perfil.slice(1)}</h4>`;
            
            if (Object.keys(permissoes).length === 0) {
                html += '<p>Nenhuma permissão definida para este perfil.</p>';
            } else {
                html += '<div class="permissions-grid">';
                
                for (const [categoria, acoes] of Object.entries(permissoes)) {
                    html += `
                        <div class="permission-category">
                            <h5>${categoria}</h5>
                    `;
                    
                    acoes.forEach(acao => {
                        html += `
                            <div class="permission-item">
                                <label>${acao}</label>
                                <i class="fas fa-check text-success"></i>
                            </div>
                        `;
                    });
                    
                    html += '</div>';
                }
                
                html += '</div>';
            }
            
            permissoesInfo.innerHTML = html;
        }

        function openTab(evt, tabName) {
            const tabcontent = document.getElementsByClassName('tab-content');
            for (let i = 0; i < tabcontent.length; i++) {
                tabcontent[i].classList.remove('active');
            }
            
            const tablinks = document.getElementsByClassName('tab');
            for (let i = 0; i < tablinks.length; i++) {
                tablinks[i].classList.remove('active');
            }
            
            document.getElementById(tabName).classList.add('active');
            evt.currentTarget.classList.add('active');
        }

        function aplicarFiltros() {
            const status = document.getElementById('status').value;
            const perfil = document.getElementById('perfil').value;
            const searchTerm = document.getElementById('search-users').value.toLowerCase();
            
            const rows = document.querySelectorAll('#utilizadores-table tbody tr');
            
            rows.forEach(row => {
                const statusCell = row.querySelector('.status-badge');
                const perfilCell = row.cells[3];
                const nomeCell = row.cells[1];
                
                let showRow = true;
                
                // Filtro por status
                if (status !== 'todos') {
                    const rowStatus = statusCell.classList.contains('status-ativo') ? 'ativo' : 
                                   statusCell.classList.contains('status-inativo') ? 'inativo' : 'suspenso';
                    if (status !== rowStatus) showRow = false;
                }
                
                // Filtro por perfil
                if (perfil !== 'todos') {
                    const perfilText = perfilCell.textContent.toLowerCase();
                    const rowPerfil = perfilText.includes('administrador') ? 'administrador' :
                                    perfilText.includes('gerente') ? 'gerente' :
                                    perfilText.includes('vendedor') ? 'vendedor' : 'caixa';
                    if (perfil !== rowPerfil) showRow = false;
                }
                
                // Filtro por busca
                if (searchTerm && !nomeCell.textContent.toLowerCase().includes(searchTerm)) {
                    showRow = false;
                }
                
                row.style.display = showRow ? '' : 'none';
            });
        }

        function limparFiltros() {
            document.getElementById('status').value = 'todos';
            document.getElementById('perfil').value = 'todos';
            document.getElementById('search-users').value = '';
            aplicarFiltros();
        }

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            // Ativar/desativar itens do menu
            const menuItems = document.querySelectorAll('.nav-menu a');
            menuItems.forEach(item => {
                item.addEventListener('click', function() {
                    menuItems.forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                });
            });
            
            // Busca em tempo real
            document.getElementById('search-users').addEventListener('input', aplicarFiltros);
            
            // Simular notificações
            const notification = document.querySelector('.notification');
            notification.addEventListener('click', function() {
                alert('Você tem 3 solicitações de acesso pendentes');
            });
        });
    </script>
