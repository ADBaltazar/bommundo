    <script>
        // Variáveis para controle do logotipo
        let logoScale = 1;
        const originalLogoSize = { width: 0, height: 0 };
        
        // Função para abrir modal
        function abrirModal(tipo) {
            document.getElementById('auth-modal').style.display = 'flex';
            alternarFormulario(tipo);
        }
        
        // Função para fechar modal
        function fecharModal() {
            document.getElementById('auth-modal').style.display = 'none';
        }
        
        // Função para alternar entre formulários
        function alternarFormulario(tipo) {
            const loginForm = document.getElementById('login-form');
            const registroForm = document.getElementById('registro-form');
            const modalTitle = document.getElementById('modal-title');
            
            if (tipo === 'login') {
                loginForm.style.display = 'block';
                registroForm.style.display = 'none';
                modalTitle.textContent = 'Login Empresarial';
            } else {
                loginForm.style.display = 'none';
                registroForm.style.display = 'block';
                modalTitle.textContent = 'Registo Empresarial';
            }
        }
        
        // Função para mostrar o dashboard (simulação de login)
        function showDashboard() {
            document.querySelector('.header').style.display = 'none';
            document.querySelector('.hero').style.display = 'none';
            document.querySelector('.services').style.display = 'none';
            document.querySelector('.footer').style.display = 'none';
            document.getElementById('dashboard').style.display = 'block';
            fecharModal();
        }
        
        // Função para voltar à página comercial
        function showCommercialPage() {
            document.querySelector('.header').style.display = 'block';
            document.querySelector('.hero').style.display = 'block';
            document.querySelector('.services').style.display = 'block';
            document.querySelector('.footer').style.display = 'block';
            document.getElementById('dashboard').style.display = 'none';
        }
        
        // Preview do logotipo
        document.getElementById('logo-empresa').addEventListener('change', function(e) {
            const file = e.target.files[0];
            const preview = document.getElementById('logo-preview');
            const fileLabel = document.getElementById('file-label');
            const logoControls = document.getElementById('logo-controls');
            
            if (file) {
                const reader = new FileReader();
                
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                    fileLabel.textContent = file.name;
                    logoControls.style.display = 'flex';
                    
                    // Salvar tamanho original
                    preview.onload = function() {
                        originalLogoSize.width = preview.naturalWidth;
                        originalLogoSize.height = preview.naturalHeight;
                        logoScale = 1;
                        aplicarEscalaLogotipo();
                    };
                }
                
                reader.readAsDataURL(file);
            }
        });
        
        // Função para ajustar o tamanho do logotipo
        function ajustarLogotipo(acao) {
            const preview = document.getElementById('logo-preview');
            
            switch(acao) {
                case 'aumentar':
                    logoScale = Math.min(logoScale + 0.1, 2); // Máximo 200%
                    break;
                case 'diminuir':
                    logoScale = Math.max(logoScale - 0.1, 0.5); // Mínimo 50%
                    break;
                case 'reset':
                    logoScale = 1;
                    break;
            }
            
            aplicarEscalaLogotipo();
        }
        
        // Aplicar escala ao logotipo
        function aplicarEscalaLogotipo() {
            const preview = document.getElementById('logo-preview');
            preview.style.width = (originalLogoSize.width * logoScale) + 'px';
            preview.style.height = (originalLogoSize.height * logoScale) + 'px';
        }
        
        // Adicionar event listeners aos formulários
        document.addEventListener('DOMContentLoaded', function() {
            // Login de empresas
            document.getElementById('login-empresa-form').addEventListener('submit', function(e) {
                e.preventDefault();
                showDashboard();
            });
            
            // Registro de empresas
            document.getElementById('registro-empresa-form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Validações
                const senha = document.getElementById('senha-empresa-registro').value;
                const confirmarSenha = document.getElementById('confirmar-senha').value;
                const termosAceitos = document.getElementById('aceitar-termos').checked;
                
                if (senha !== confirmarSenha) {
                    alert('As senhas não coincidem!');
                    return;
                }
                
                if (!termosAceitos) {
                    alert('É necessário aceitar os Termos e Condições para criar uma conta.');
                    return;
                }
                
                // Simular sucesso
                alert('Conta empresarial criada com sucesso! Em breve você receberá um e-mail de confirmação.');
                this.reset();
                document.getElementById('logo-preview').style.display = 'none';
                document.getElementById('file-label').textContent = 'Clique para fazer upload do logotipo';
                document.getElementById('logo-controls').style.display = 'none';
                alternarFormulario('login');
            });
            
            // Fechar modal ao clicar fora
            window.addEventListener('click', function(e) {
                const modal = document.getElementById('auth-modal');
                if (e.target === modal) {
                    fecharModal();
                }
            });
            
            // Fechar modal com ESC
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    fecharModal();
                }
            });
        });
    </script>
