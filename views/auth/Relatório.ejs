        }

        function showGerarRelatorio() {
            document.getElementById('page-title').textContent = 'Gerar Relatório';
            const template = document.getElementById('gerar-relatorio-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
            
            // Inicializar funcionalidades do formulário
            document.getElementById('gerar-relatorio-form').addEventListener('submit', function(e) {
                e.preventDefault();
                
                // Simular geração de relatório
                document.getElementById('success-alert').textContent = 'Relatório em processamento! Você será notificado quando estiver pronto.';
                document.getElementById('success-alert').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('success-alert').style.display = 'none';
                    showRelatoriosList();
                }, 3000);
            });
            
            // Atualizar pré-visualização quando o tipo mudar
            document.getElementById('tipo_relatorio').addEventListener('change', function() {
                atualizarCamposRelatorio();
                atualizarPreview();
            });
            
            // Definir datas padrão
            const hoje = new Date();
            const primeiroDiaMes = new Date(hoje.getFullYear(), hoje.getMonth(), 1);
            
            document.getElementById('data_inicio').value = primeiroDiaMes.toISOString().split('T')[0];
            document.getElementById('data_fim').value = hoje.toISOString().split('T')[0];
        }

