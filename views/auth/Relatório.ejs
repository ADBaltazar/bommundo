            const status = document.getElementById('status').value;
            const dataInicio = document.getElementById('data_inicio').value;
            const dataFim = document.getElementById('data_fim').value;
            const searchTerm = document.getElementById('search-reports').value.toLowerCase();
            
            const rows = document.querySelectorAll('#relatorios-table tbody tr');
            
            rows.forEach(row => {
                const tipoCell = row.cells[2];
                const statusCell = row.querySelector('.status-badge');
                const dataCell = row.cells[3];
                const nomeCell = row.cells[1];
                
                let showRow = true;
                
                // Filtro por tipo
                if (tipo !== 'todos') {
                    const tipoText = tipoCell.textContent.toLowerCase();
                    const rowTipo = tipoText.includes('vendas') ? 'vendas' :
                                  tipoText.includes('estoque') ? 'estoque' :
                                  tipoText.includes('clientes') ? 'clientes' :
                                  tipoText.includes('financeiro') ? 'financeiro' : 'customizado';
                    if (tipo !== rowTipo) showRow = false;
                }
                
                // Filtro por status
                if (status !== 'todos') {
                    const statusText = statusCell.textContent.toLowerCase();
                    const rowStatus = statusText.includes('concluído') ? 'concluido' :
                                    statusText.includes('processando') ? 'processando' :
                                    statusText.includes('erro') ? 'erro' : 'pendente';
                    if (status !== rowStatus) showRow = false;
                }
                
                // Filtro por data
                if (dataInicio && dataFim) {
                    const dataRow = new Date(dataCell.textContent.split(' ')[0].split('/').reverse().join('-'));
                    const inicio = new Date(dataInicio);
                    const fim = new Date(dataFim);
                    
                    if (dataRow < inicio || dataRow > fim) showRow = false;
                }
                
                // Filtro por busca
                if (searchTerm && !nomeCell.textContent.toLowerCase().includes(searchTerm)) {
                    showRow = false;
                }
                
                row.style.display = showRow ? '' : 'none';
            });
        }

        function limparFiltros() {
            document.getElementById('tipo_relatorio').value = 'todos';
            document.getElementById('status').value = 'todos';
            document.getElementById('data_inicio').value = '';
            document.getElementById('data_fim').value = '';
            document.getElementById('search-reports').value = '';
            aplicarFiltros();
        }

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            // Ativar/desativar itens do menu
            const menuItems = document.querySelectorAll('.nav-menu a');
            menuItems.forEach(item => {
                item.addEventListener('click', function() {
                    menuItems.forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                });
            });
            
            // Busca em tempo real
            document.getElementById('search-reports').addEventListener('input', aplicarFiltros);
            
            // Simular notificações
            const notification = document.querySelector('.notification');
            notification.addEventListener('click', function() {
                alert('Você tem 2 relatórios prontos para download');
            });
        });
    </script>
</body>
</html>