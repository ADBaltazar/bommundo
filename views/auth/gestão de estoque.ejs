                                    <td>
                                        <span class="text-danger">3</span>
                                    </td>
                                    <td>5</td>
                                    <td>
                                        <span class="status-badge status-ativo">Ativo</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" onclick="showEditProductForm()">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
                                        <button class="btn btn-sm btn-danger">
                                            <i class="fas fa-times"></i> Desativar
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>1002</td>
                                    <td>Impressora HP LaserJet</td>
                                    <td>7891234567891</td>
                                    <td>R$ 800,00</td>
                                    <td>R$ 1.100,00</td>
                                    <td>12</td>
                                    <td>3</td>
                                    <td>
                                        <span class="status-badge status-ativo">Ativo</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" onclick="showEditProductForm()">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
                                        <button class="btn btn-sm btn-danger">
                                            <i class="fas fa-times"></i> Desativar
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>1003</td>
                                    <td>Resma de Papel A4</td>
                                    <td>7891234567892</td>
                                    <td>R$ 15,00</td>
                                    <td>R$ 22,00</td>
                                    <td>
                                        <span class="text-danger">2</span>
                                    </td>
                                    <td>10</td>
                                    <td>
                                        <span class="status-badge status-ativo">Ativo</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" onclick="showEditProductForm()">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
                                        <button class="btn btn-sm btn-danger">
                                            <i class="fas fa-times"></i> Desativar
                                        </button>
                                    </td>
                                </tr>
                                <tr>
                                    <td>1004</td>
                                    <td>Mouse Óptico USB</td>
                                    <td>7891234567893</td>
                                    <td>R$ 12,00</td>
                                    <td>R$ 25,00</td>
                                    <td>25</td>
                                    <td>5</td>
                                    <td>
                                        <span class="status-badge status-ativo">Ativo</span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-warning" onclick="showEditProductForm()">
                                            <i class="fas fa-edit"></i> Editar
                                        </button>
