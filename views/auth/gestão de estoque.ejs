                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Templates para as diferentes páginas -->
    
    <!-- Template: Adicionar Produto -->
    <template id="add-product-template">
        <div class="page-header">
            <h2>Adicionar Novo Produto</h2>
            <button class="btn btn-secondary" onclick="showProductList()">
                <i class="fas fa-arrow-left"></i> Voltar
            </button>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h3>Informações do Produto</h3>
                    </div>
                    <div class="card-body">
                        <form id="add-product-form">
                            <div class="form-group">
                                <label for="nome" class="form-label">Nome do Produto:</label>
                                <input type="text" id="nome" name="nome" class="form-control" required>
                            </div>
                            
                            <div class="form-group">
                                <label for="descricao" class="form-label">Descrição:</label>
                                <textarea id="descricao" name="descricao" class="form-control" rows="3"></textarea>
                            </div>
                            
                            <div class="form-group">
                                <label for="codigo_barras" class="form-label">Código de Barras:</label>
                                <input type="text" id="codigo_barras" name="codigo_barras" class="form-control">
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="preco_custo" class="form-label">Preço de Custo (R$):</label>
                                        <input type="number" id="preco_custo" name="preco_custo" class="form-control" 
                                            step="0.01" min="0" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="preco_venda" class="form-label">Preço de Venda (R$):</label>
                                        <input type="number" id="preco_venda" name="preco_venda" class="form-control" 
                                            step="0.01" min="0" required>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="quantidade_estoque" class="form-label">Quantidade em Estoque:</label>
                                        <input type="number" id="quantidade_estoque" name="quantidade_estoque" class="form-control" 
                                            min="0" value="0" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="quantidade_minima" class="form-label">Estoque Mínimo:</label>
                                        <input type="number" id="quantidade_minima" name="quantidade_minima" class="form-control" 
                                            min="0" value="5" required>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label for="categoria_id" class="form-label">Categoria:</label>
                                <select id="categoria_id" name="categoria_id" class="form-control">
                                    <option value="">Sem categoria</option>
                                    <option value="1">Computadores</option>
                                    <option value="2">Impressoras</option>
                                    <option value="3">Suprimentos</option>
                                    <option value="4">Periféricos</option>
                                    <option value="5">Acessórios</option>
                                </select>
                            </div>
                            
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-plus"></i> Adicionar Produto
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <!-- Template: Editar Produto -->
    <template id="edit-product-template">
        <div class="page-header">
            <h2>Editar Produto</h2>
            <button class="btn btn-secondary" onclick="showProductList()">
                <i class="fas fa-arrow-left"></i> Voltar
            </button>
        </div>

        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header">
                        <h3>Informações do Produto</h3>
                    </div>
                    <div class="card-body">
                        <form id="edit-product-form">
                            <div class="form-group">
                                <label for="edit-nome" class="form-label">Nome do Produto:</label>
                                <input type="text" id="edit-nome" name="nome" class="form-control" value="Notebook Dell Inspiron" required>
                            </div>
                            
                            <div class="form-group">
                                <label for="edit-descricao" class="form-label">Descrição:</label>
                                <textarea id="edit-descricao" name="descricao" class="form-control" rows="3">Notebook Dell Inspiron 15, Intel Core i5, 8GB RAM, 256GB SSD</textarea>
                            </div>
                            
                            <div class="form-group">
                                <label for="edit-codigo_barras" class="form-label">Código de Barras:</label>
                                <input type="text" id="edit-codigo_barras" name="codigo_barras" class="form-control" value="7891234567890">
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="edit-preco_custo" class="form-label">Preço de Custo (R$):</label>
                                        <input type="number" id="edit-preco_custo" name="preco_custo" class="form-control" 
                                            step="0.01" min="0" value="2500.00" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="edit-preco_venda" class="form-label">Preço de Venda (R$):</label>
                                        <input type="number" id="edit-preco_venda" name="preco_venda" class="form-control" 
                                            step="0.01" min="0" value="3200.00" required>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="edit-quantidade_estoque" class="form-label">Quantidade em Estoque:</label>
                                        <input type="number" id="edit-quantidade_estoque" name="quantidade_estoque" class="form-control" 
                                            min="0" value="3" required>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label for="edit-quantidade_minima" class="form-label">Estoque Mínimo:</label>
                                        <input type="number" id="edit-quantidade_minima" name="quantidade_minima" class="form-control" 
                                            min="0" value="5" required>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-group">
                                <label for="edit-categoria_id" class="form-label">Categoria:</label>
                                <select id="edit-categoria_id" name="categoria_id" class="form-control">
                                    <option value="">Sem categoria</option>
                                    <option value="1" selected>Computadores</option>
                                    <option value="2">Impressoras</option>
                                    <option value="3">Suprimentos</option>
                                    <option value="4">Periféricos</option>
                                    <option value="5">Acessórios</option>
                                </select>
                            </div>
                            
                            <button type="submit" class="btn btn-primary btn-block">
                                <i class="fas fa-save"></i> Atualizar Produto
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </template>

    <script>
        // Funções para navegação entre páginas
        function showProductList() {
            document.getElementById('page-title').textContent = 'Gestão de Produtos';
            document.getElementById('page-content').innerHTML = document.querySelector('#page-content').innerHTML;
        }

        function showAddProductForm() {
            document.getElementById('page-title').textContent = 'Adicionar Produto';
            const template = document.getElementById('add-product-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
            
            // Adicionar evento de submit ao formulário
            document.getElementById('add-product-form').addEventListener('submit', function(e) {
                e.preventDefault();
                // Simular sucesso
                document.getElementById('success-alert').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('success-alert').style.display = 'none';
                    showProductList();
                }, 3000);
            });
        }

        function showEditProductForm() {
            document.getElementById('page-title').textContent = 'Editar Produto';
            const template = document.getElementById('edit-product-template');
            document.getElementById('page-content').innerHTML = template.innerHTML;
            
            // Adicionar evento de submit ao formulário
            document.getElementById('edit-product-form').addEventListener('submit', function(e) {
                e.preventDefault();
                // Simular sucesso
                document.getElementById('success-alert').style.display = 'block';
                setTimeout(() => {
                    document.getElementById('success-alert').style.display = 'none';
                    showProductList();
                }, 3000);
            });
        }

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            // Ativar/desativar itens do menu
            const menuItems = document.querySelectorAll('.nav-menu a');
            menuItems.forEach(item => {
                item.addEventListener('click', function() {
                    menuItems.forEach(i => i.classList.remove('active'));
                    this.classList.add('active');
                });
            });
            
            // Simular notificações
            const notification = document.querySelector('.notification');
            notification.addEventListener('click', function() {
                alert('Você tem 3 notificações não lidas');
            });
        });
    </script>
</body>
</html>