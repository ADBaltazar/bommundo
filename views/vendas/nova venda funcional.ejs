
<div class="container">
    <h2>Nova Venda tttt</h2>
    
    <% if (!caixa) { %>
        <div class="alert alert-warning">
            <strong>Atenção!</strong> Não há caixa aberto. 
            <a href="/caixa/abrir" class="alert-link">Abra um caixa</a> antes de realizar vendas.
        </div>
    <% } else { %>
        <div class="alert alert-info">
            Caixa aberto: #<%= caixa.id %> | Valor inicial: R$ <%= caixa.valor_abertura %>
        </div>
        
        <form id="vendaForm" method="POST" action="/vendas/nova">
            <div class="row">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header">
                            <h3>Produtos</h3>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label for="produtoSearch" class="form-label">Buscar Produto:</label>
                                <input type="text" id="produtoSearch" class="form-control" placeholder="Digite o nome ou código do produto">
                            </div>
                            
                            <div id="produtosList" class="produtos-list">
                                <% produtos.forEach(produto => { %>
                                    <div class="produto-item" data-id="<%= produto.id %>" data-preco="<%= produto.preco_venda %>" data-estoque="<%= produto.quantidade_estoque %>">
                                        <div class="produto-info">
                                            <h5><%= produto.nome %></h5>
                                            <p>Código: <%= produto.codigo_barras || 'N/A' %></p>
                                            <p>Estoque: <%= produto.quantidade_estoque %> | Preço: R$ <%= produto.preco_venda %></p>
                                        </div>
                                        <button type="button" class="btn btn-primary btn-add-produto">Adicionar</button>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                    
                    <div class="card mt-3">
                        <div class="card-header">
                            <h3>Itens da Venda</h3>
                        </div>
                        <div class="card-body">
                            <div id="carrinhoVazio" class="text-center py-4" style="display: none;">
                                <p>Nenhum produto adicionado ao carrinho</p>
                            </div>
                            
                            <table id="tabelaItens" class="data-table" style="display: none;">
                                <thead>
                                    <tr>
                                        <th>Produto</th>
                                        <th>Quantidade</th>
                                        <th>Preço Unit.</th>
                                        <th>Subtotal</th>
                                        <th>Ação</th>
                                    </tr>
                                </thead>
                                <tbody id="itensCarrinho">
                                    <!-- Itens serão adicionados aqui via JavaScript -->
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="3" class="text-end"><strong>Total:</strong></td>
                                        <td id="totalVenda">R$ 0,00</td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
                
                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">
                            <h3>Informações da Venda</h3>
                        </div>
                        <div class="card-body">
                            <div class="form-group">
                                <label for="forma_pagamento" class="form-label">Forma de Pagamento:</label>
                                <select id="forma_pagamento" name="forma_pagamento" class="form-control" required>
                                    <option value="">Selecione...</option>
                                    <option value="dinheiro">Dinheiro</option>
                                    <option value="cartao_debito">Cartão de Débito</option>
                                    <option value="cartao_credito">Cartão de Crédito</option>
                                    <option value="pix">PIX</option>
                                    <option value="transferencia">Transferência</option>
                                </select>
                            </div>
                            
                            <div class="form-group">
                                <label for="desconto" class="form-label">Desconto (R$):</label>
                                <input type="number" id="desconto" name="desconto" class="form-control" value="0" min="0" step="0.01" onchange="calcularTotal()">
                            </div>
                            
                            <div class="form-group">
                                <label class="form-label">Total com Desconto:</label>
                                <h3 id="totalComDesconto">R$ 0,00</h3>
                            </div>
                            
                            <button type="submit" class="btn btn-success btn-lg btn-block">Finalizar Venda</button>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- Campos hidden para enviar os dados -->
            <input type="hidden" id="produtosData" name="produtos">
            <input type="hidden" id="quantidadesData" name="quantidades">
        </form>
    <% } %>
</div>

<script>
let carrinho = [];
let totalVenda = 0;

// Busca de produtos
document.getElementById('produtoSearch').addEventListener('input', function(e) {
    const searchTerm = e.target.value.toLowerCase();
    const produtos = document.querySelectorAll('.produto-item');
    
    produtos.forEach(produto => {
        const nome = produto.querySelector('h5').textContent.toLowerCase();
        const codigo = produto.querySelector('p').textContent.toLowerCase();
        
        if (nome.includes(searchTerm) || codigo.includes(searchTerm)) {
            produto.style.display = 'flex';
        } else {
            produto.style.display = 'none';
        }
    });
});

// Adicionar produto ao carrinho
document.querySelectorAll('.btn-add-produto').forEach(btn => {
    btn.addEventListener('click', function() {
        const produtoItem = this.closest('.produto-item');
        const produtoId = produtoItem.dataset.id;
        const produtoNome = produtoItem.querySelector('h5').textContent;
        const preco = parseFloat(produtoItem.dataset.preco);
        const estoque = parseInt(produtoItem.dataset.estoque);
        
        // Verificar se produto já está no carrinho
        const itemExistente = carrinho.find(item => item.id === produtoId);
        
        if (itemExistente) {
            if (itemExistente.quantidade < estoque) {
                itemExistente.quantidade++;
                itemExistente.subtotal = itemExistente.quantidade * preco;
                atualizarItemCarrinho(produtoId);
            } else {
                alert('Estoque insuficiente para este produto!');
            }
        } else {
            if (estoque > 0) {
                carrinho.push({
                    id: produtoId,
                    nome: produtoNome,
                    preco: preco,
                    quantidade: 1,
                    subtotal: preco
                });
                adicionarItemCarrinho(produtoId, produtoNome, preco, 1, preco);
            } else {
                alert('Produto sem estoque disponível!');
            }
        }
        
        atualizarTotal();
        atualizarVisibilidadeCarrinho();
    });
});

// Funções para manipular o carrinho
function adicionarItemCarrinho(id, nome, preco, quantidade, subtotal) {
    const tbody = document.getElementById('itensCarrinho');
    const tr = document.createElement('tr');
    tr.id = `item-${id}`;
    tr.innerHTML = `
        <td>${nome}</td>
        <td>
            <div class="quantidade-control">
                <button type="button" class="btn btn-sm btn-secondary" onclick="alterarQuantidade('${id}', -1)">-</button>
                <span class="quantidade">${quantidade}</span>
                <button type="button" class="btn btn-sm btn-secondary" onclick="alterarQuantidade('${id}', 1)">+</button>
            </div>
        </td>
        <td>R$ ${preco.toFixed(2)}</td>
        <td>R$ ${subtotal.toFixed(2)}</td>
        <td>
            <button type="button" class="btn btn-sm btn-danger" onclick="removerItem('${id}')">×</button>
        </td>
    `;
    tbody.appendChild(tr);
}

function atualizarItemCarrinho(id) {
    const item = carrinho.find(item => item.id === id);
    if (item) {
        const tr = document.getElementById(`item-${id}`);
        tr.querySelector('.quantidade').textContent = item.quantidade;
        tr.querySelector('td:nth-child(4)').textContent = `R$ ${item.subtotal.toFixed(2)}`;
    }
}

function alterarQuantidade(id, change) {
    const item = carrinho.find(item => item.id === id);
    if (item) {
        const novoTotal = item.quantidade + change;
        const estoque = parseInt(document.querySelector(`.produto-item[data-id="${id}"]`).dataset.estoque);
        
        if (novoTotal > 0 && novoTotal <= estoque) {
            item.quantidade = novoTotal;
            item.subtotal = item.quantidade * item.preco;
            atualizarItemCarrinho(id);
            atualizarTotal();
        } else if (novoTotal > estoque) {
            alert('Estoque insuficiente!');
        }
    }
}

function removerItem(id) {
    carrinho = carrinho.filter(item => item.id !== id);
    document.getElementById(`item-${id}`).remove();
    atualizarTotal();
    atualizarVisibilidadeCarrinho();
}

function atualizarTotal() {
    totalVenda = carrinho.reduce((total, item) => total + item.subtotal, 0);
    document.getElementById('totalVenda').textContent = `R$ ${totalVenda.toFixed(2)}`;
    calcularTotal();
}

function calcularTotal() {
    const desconto = parseFloat(document.getElementById('desconto').value) || 0;
    const totalComDesconto = Math.max(0, totalVenda - desconto);
    document.getElementById('totalComDesconto').textContent = `R$ ${totalComDesconto.toFixed(2)}`;
}

function atualizarVisibilidadeCarrinho() {
    const carrinhoVazio = document.getElementById('carrinhoVazio');
    const tabelaItens = document.getElementById('tabelaItens');
    
    if (carrinho.length === 0) {
        carrinhoVazio.style.display = 'block';
        tabelaItens.style.display = 'none';
    } else {
        carrinhoVazio.style.display = 'none';
        tabelaItens.style.display = 'table';
    }
}

// Submit do formulário
document.getElementById('vendaForm').addEventListener('submit', function(e) {
    if (carrinho.length === 0) {
        e.preventDefault();
        alert('Adicione pelo menos um produto à venda!');
        return;
    }
    
    // Preparar dados para envio
    const produtos = carrinho.map(item => item.id);
    const quantidades = carrinho.map(item => item.quantidade);
    
    document.getElementById('produtosData').value = JSON.stringify(produtos);
    document.getElementById('quantidadesData').value = JSON.stringify(quantidades);
});

// Inicializar visibilidade do carrinho
atualizarVisibilidadeCarrinho();
</script>

<style>
.produto-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 4px;
    margin-bottom: 10px;
}

.produto-info h5 {
    margin: 0;
    font-size: 16px;
}

.quantidade-control {
    display: flex;
    align-items: center;
    gap: 5px;
}

.quantidade-control .quantidade {
    margin: 0 10px;
    font-weight: bold;
}

.status-badge {
    padding: 4px 8px;
    border-radius: 12px;
    font-size: 12px;
    font-weight: bold;
}

.status-pendente {
    background-color: #fff3cd;
    color: #856404;
}

.status-concluida {
    background-color: #d4edda;
    color: #155724;
}

.status-cancelada {
    background-color: #f8d7da;
    color: #721c24;
}
</style>
